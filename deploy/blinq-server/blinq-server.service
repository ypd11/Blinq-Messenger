[Unit]
Description=Blinq Messenger Account Server
After=network.target

[Service]
Type=simple
User=blinq
Group=blinq
WorkingDirectory=/opt/blinq-server
EnvironmentFile=/etc/blinq-server.env
ExecStart=/usr/bin/node /opt/blinq-server/server.js
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
